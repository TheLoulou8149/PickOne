# Copiez ce fichier en .env et remplissez vos clés API

# Google Gemini (recommandé pour les tests)
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_key_here

# Anthropic Claude (optionnel)
EXPO_PUBLIC_ANTHROPIC_API_KEY=your_anthropic_key_here

# OpenAI (optionnel)
EXPO_PUBLIC_OPENAI_API_KEY=your_openai_key_here

# Choisir le provider : "gemini" | "anthropic" | "openai"
EXPO_PUBLIC_LLM_PROVIDER=gemini
